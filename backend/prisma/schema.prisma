generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ──────────── Enums ────────────
enum ExerciseType {
  MULTIPLE_CHOICE
  FILL_BLANK
  LISTENING
  TRANSLATION
  REORDER
  ARABIC_KEYBOARD // saisie arabe (clavier QWERTY phonétique ou layout AR)
  DRAWING // coloriage / collage / tracé libre
  MATCHING // appariement (relier audio ↔ réponse, image ↔ mot)
  DUEL // exercice utilisé en mode duel synchrone
}

enum PartOfSpeech {
  NOUN
  VERB
  ADJECTIVE
  ADVERB
  PRONOUN
  PREPOSITION
  CONJUNCTION
  INTERJECTION
}

enum LangTrack {
  DARIJA
  MSA
  BOTH
}

/// Track de navigation top-level (3 onglets côté UI : Darija / MSA / Religion).
enum ModuleTrack {
  DARIJA
  MSA
  RELIGION
}

/// Métadonnées éditables des 3 tracks top-level (onglets du parcours).
/// Le `code` reprend la valeur de l'enum ModuleTrack (DARIJA / MSA / RELIGION).
model Track {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  nameAr      String?
  description String?
  emoji       String?
  color       String?
  order       Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

enum DuelStatus {
  WAITING // en attente d'un adversaire
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

/// Position d'une révision dans un module (check-point milieu ou synthèse fin).
enum RevisionPosition {
  MIDDLE
  END
}

/// ──────────── Core ────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String?
  avatar       String?
  locale       String   @default("fr")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isDeleted    Boolean  @default(false)

  // Gamification
  xp           Int       @default(0)
  level        Int       @default(1)
  streak       Int       @default(0)
  lastStreakAt DateTime?
  hearts       Int       @default(5)
  gemmes       Int       @default(0)

  // Préférences UI synchronisées entre devices (PWA web, mobile).
  // Source de vérité côté serveur ; le client cache en localStorage pour la perf.
  langTrack       LangTrack @default(DARIJA)
  preferredMascot String?   // chemin image, ex: '/images/maroccan-lion.png'
  nodeShape       String?   // 'star' | 'circle' | 'arch' | 'hex' | 'medallion' | 'crown'
  pathStyle       String?   // 'serpentin' | 'calligraphie'

  // Souscription
  subscriptionStatus    String?   @default("free")
  subscriptionExpiresAt DateTime?

  // Push notifications (OneSignal)
  oneSignalSubId    String?
  pushOptedInAt     DateTime?
  lastStreakNotifAt DateTime?

  // Relations (toutes les FK déclarées explicitement pour intégrité référentielle)
  lessonsAuthored      Lesson[]               @relation("AuthorLessons")
  progress             UserProgress[]
  vocabularies         UserVocabulary[]
  badges               UserBadge[]
  conversationMessages ConversationMessage[]
  inventory            UserInventory[]
  friendRequestsSent   FriendRequest[]        @relation("FriendRequestFrom")
  friendRequestsRecv   FriendRequest[]        @relation("FriendRequestTo")
  leagueMembership     LeagueMembership?
  analyticsEvents      AnalyticsEvent[]
  dailyQuests          DailyQuestProgress[]
  monthlyQuests        MonthlyQuestProgress[]
  duelsAsP1            Duel[]                 @relation("DuelP1")
  duelsAsP2            Duel[]                 @relation("DuelP2")
  duelsWon             Duel[]                 @relation("DuelWinner")
  culturalUnlocks      UserCulturalUnlock[]
  revisionProgress     UserRevisionProgress[]

  @@index([email])
  @@index([xp])
}

model Language {
  id        String   @id @default(cuid())
  code      String   @unique // 'ar-MA', 'ar-SA', 'fr', 'en'
  name      String
  createdAt DateTime @default(now())

  lessons    Lesson[]
  vocabulary Vocabulary[]
}

model Module {
  id             String      @id @default(cuid())
  title          String
  titleAr        String?
  subtitle       String?
  description    String?
  level          Int         @default(1)
  slug           String      @unique
  /// Track de navigation top-level (DARIJA / MSA / RELIGION).
  track          ModuleTrack @default(MSA)
  /// Position canonique du module dans son track (0-based, ordre pédagogique).
  /// Permet l'alignement Darija ↔ MSA (même `canonicalOrder` = même thème).
  canonicalOrder Int         @default(0)
  colorA         String?
  colorB         String?
  shadowColor    String?
  /// Nom de la ville isolé du titre (ex: "Tanger", "Casablanca").
  cityName       String?
  cityNameAr     String?
  /// Emoji de la section parcours (fallback lecture → cityInfo.emoji).
  emoji          String?
  /// Sous-titre affiché sur la carte ville (ex: "Porte du détroit...").
  photoCaption   String?
  /// Infos ville affichées au clic sur le bandeau de la section. Shape :
  /// { emoji, photoUrl, history, typicalWord: { ar, latin, fr },
  /// food, culturalFact, toSee, music }. Tous champs optionnels.
  cityInfo       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  isPublished    Boolean     @default(false)

  lessons   Lesson[]
  revisions ModuleRevision[]

  @@index([slug])
  @@index([track, canonicalOrder])
  @@index([level, createdAt])
}

/// Révision = dialogue court en Darija/FR/MSA réutilisant le vocabulaire du
/// module. Deux points d'insertion par module : MIDDLE (check-point, ~50%)
/// et END (synthèse avant trophée). Contenu rédigé à la main en admin.
/// content JSON shape :
///   { setting?: string, theme?: string, turns: [
///       { speaker: 'A' | 'B', darija: string, french: string,
///         transliteration?: string, audioUrl?: string }
///     ] }
model ModuleRevision {
  id               String           @id @default(cuid())
  module           Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId         String
  position         RevisionPosition
  title            String?
  content          Json
  isPublished      Boolean          @default(false)
  /// Insère la pseudo-ligne après la leçon d'index `anchorAfterOrder` (0-indexed).
  /// null → défaut (MIDDLE = floor(n/2), END = après la dernière leçon).
  anchorAfterOrder Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  progress UserRevisionProgress[]

  @@unique([moduleId, position])
  @@index([moduleId])
  @@index([isPublished])
}

/// Progression d'un utilisateur sur une révision (complétion unique).
/// Un seul enregistrement par (user, revision). Le champ completedAt sert à
/// l'analytics ; l'existence suffit à considérer la révision comme faite.
model UserRevisionProgress {
  id          String         @id @default(cuid())
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  revision    ModuleRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  revisionId  String
  completedAt DateTime       @default(now())

  @@unique([userId, revisionId])
  @@index([userId])
  @@index([revisionId])
}

model Lesson {
  id          String   @id @default(cuid())
  title       String
  slug        String?  @unique
  subtitle    String?
  description String?
  content     Json?
  order       Int      @default(0)
  duration    Int?
  level       Int      @default(1)
  videoUrl    String?
  videoPoster String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isPublished Boolean  @default(false)
  isDeleted   Boolean  @default(false)

  module     Module?  @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  moduleId   String?
  author     User?    @relation("AuthorLessons", fields: [authorId], references: [id], onDelete: SetNull)
  authorId   String?
  language   Language @relation(fields: [languageId], references: [id])
  languageId String

  exercises        Exercise[]
  authoredExercises LessonExercise[]
  userProgress     UserProgress[]
  duels            Duel[]

  @@index([moduleId, order])
  @@index([languageId, level])
  @@index([isPublished, isDeleted])
}

/// Exercice authoré (config explicite — supplante la séquence auto-générée).
/// Si une leçon a >= 1 LessonExercise, le runtime les utilise au lieu de
/// générer la séquence à partir du vocabulaire + sequence par défaut.
model LessonExercise {
  id          String   @id @default(cuid())
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId    String
  order       Int      @default(0)
  typology    String   // clé du registry web : "FlashCard", "ChoixLettre", etc.
  config      Json     // forme spécifique à la typologie (vocabIds, distractors, pairs, ...)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([lessonId, order])
  @@index([typology])
  @@index([lessonId, isPublished])
}

model Vocabulary {
  id              String        @id @default(cuid())
  word            String
  transliteration String?
  translation     Json?
  audioUrl        String?
  imageUrl        String?
  partOfSpeech    PartOfSpeech?
  examples        Json?
  tags            String[]      @default([])
  isPublished     Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  language        Language      @relation(fields: [languageId], references: [id])
  languageId      String

  exercises Exercise[]
  users     UserVocabulary[]
  packWords PackWord[]

  @@index([word])
  @@index([languageId, word])
  @@index([isPublished])
}

model Exercise {
  id        String       @id @default(cuid())
  type      ExerciseType
  prompt    String?
  data      Json?
  answer    Json?
  points    Int          @default(10)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  lesson       Lesson?     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId     String?
  vocabulary   Vocabulary? @relation(fields: [vocabularyId], references: [id], onDelete: SetNull)
  vocabularyId String?

  @@index([lessonId])
  @@index([vocabularyId])
  @@index([type])
}

model Badge {
  id          String   @id @default(cuid())
  key         String   @unique
  title       String
  description String?
  icon        String?
  points      Int      @default(0)
  createdAt   DateTime @default(now())

  userBadges UserBadge[]
}

/// ──────────── Progression ────────────
model UserBadge {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  badgeId   String
  awardedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
}

model UserVocabulary {
  id           String     @id @default(cuid())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  vocabulary   Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
  vocabularyId String
  mastery      Int        @default(0)
  lastSeenAt   DateTime?
  nextReviewAt DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([userId, vocabularyId])
  @@index([userId, nextReviewAt])
}

model UserProgress {
  id         String    @id @default(cuid())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  lesson     Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId   String
  completed  Boolean   @default(false)
  progress   Int       @default(0)
  xpEarned   Int       @default(0)
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  updatedAt  DateTime  @updatedAt

  @@unique([userId, lessonId])
  @@index([userId, updatedAt])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  type      String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

/// ──────────── Social ────────────
model FriendRequest {
  id        String   @id @default(cuid())
  from      User     @relation("FriendRequestFrom", fields: [fromId], references: [id], onDelete: Cascade)
  fromId    String
  to        User     @relation("FriendRequestTo", fields: [toId], references: [id], onDelete: Cascade)
  toId      String
  status    String   @default("pending") // pending | accepted | rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fromId, toId])
  @@index([fromId])
  @@index([toId])
  @@index([status])
}

model LeagueMembership {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique
  league    String // Bronze | Silver | Gold | Diamond | Master
  points    Int      @default(0)
  updatedAt DateTime @updatedAt

  @@index([league, points(sort: Desc)])
}

/// ──────────── Duels temps réel ────────────
model Duel {
  id         String     @id @default(cuid())
  p1         User       @relation("DuelP1", fields: [p1Id], references: [id], onDelete: Cascade)
  p1Id       String
  p2         User?      @relation("DuelP2", fields: [p2Id], references: [id], onDelete: SetNull)
  p2Id       String?
  winner     User?      @relation("DuelWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  winnerId   String?
  lesson     Lesson?    @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  lessonId   String?
  status     DuelStatus @default(WAITING)
  scoreP1    Int        @default(0)
  scoreP2    Int        @default(0)
  rounds     Int        @default(5)
  data       Json? // questions snapshot, timing, etc.
  createdAt  DateTime   @default(now())
  startedAt  DateTime?
  finishedAt DateTime?

  @@index([status, createdAt])
  @@index([p1Id])
  @@index([p2Id])
}

/// ──────────── Boutique culturelle ────────────
model VocabularyPack {
  id          String   @id @default(cuid())
  title       String
  description String?
  difficulty  String?
  category    String?
  premiumOnly Boolean  @default(false)
  createdAt   DateTime @default(now())

  words PackWord[]

  @@index([difficulty])
  @@index([category])
}

model PackWord {
  id           String         @id @default(cuid())
  pack         VocabularyPack @relation(fields: [packId], references: [id], onDelete: Cascade)
  packId       String
  vocabulary   Vocabulary     @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
  vocabularyId String

  @@index([packId])
  @@index([vocabularyId])
}

model ConversationMessage {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String?
  role      String // 'user' | 'bot'
  text      String
  audioUrl  String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model ShopItem {
  id          String          @id @default(cuid())
  key         String          @unique
  name        String
  description String
  icon        String
  category    String // 'consumable' | 'cosmetic' | 'pack' | 'cultural'
  price       Int
  effect      Json?
  isAvailable Boolean         @default(true)
  createdAt   DateTime        @default(now())
  purchases   UserInventory[]
}

model UserInventory {
  id        String    @id @default(cuid())
  userId    String
  itemKey   String
  quantity  Int       @default(1)
  isActive  Boolean   @default(false)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  item      ShopItem  @relation(fields: [itemKey], references: [key], onDelete: Cascade)

  @@index([userId])
  @@index([itemKey])
}

/// Collection culturelle marocaine (plats, musique, lieux, monuments).
/// Débloquée par achat boutique, complétion de cours, ou récompenses streak.
model CulturalItem {
  id          String   @id @default(cuid())
  key         String   @unique // 'tajine', 'gnawa-music', 'jamaa-el-fna', etc.
  category    String // 'food' | 'music' | 'place' | 'monument' | 'tradition'
  name        String
  nameAr      String?
  description String?
  imageUrl    String?
  audioUrl    String?
  region      String? // Casablanca, Marrakech, Fès, etc.
  rarity      String   @default("common") // common | rare | epic | legendary
  unlockHint  String? // ex. "Termine le module Nourriture"
  createdAt   DateTime @default(now())

  unlocks UserCulturalUnlock[]

  @@index([category])
  @@index([rarity])
}

model UserCulturalUnlock {
  id         String       @id @default(cuid())
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  item       CulturalItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId     String
  unlockedAt DateTime     @default(now())
  source     String? // 'shop' | 'lesson' | 'streak' | 'duel'

  @@unique([userId, itemId])
  @@index([userId])
}

/// ──────────── Quêtes ────────────
model DailyQuestProgress {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  date      String // YYYY-MM-DD
  questKey  String // 'xp_50' | 'lessons_2' | 'streak' | 'score_90'
  current   Int       @default(0)
  completed Boolean   @default(false)
  claimedAt DateTime?
  createdAt DateTime  @default(now())

  @@unique([userId, date, questKey])
  @@index([userId, date])
}

model MonthlyQuestProgress {
  id           String    @id @default(cuid())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  yearMonth    String // YYYY-MM
  questsDone   Int       @default(0)
  questsTarget Int       @default(30)
  completed    Boolean   @default(false)
  claimedAt    DateTime?
  createdAt    DateTime  @default(now())

  @@unique([userId, yearMonth])
  @@index([userId])
}
