    {
      "id": "phrase_3",
      "ar": "أُمِّي وَ أَبِي وَ أُخْتِي وَ أَخِي وَ جَدِّي وَ جَدَّتِي.",
      "fr": "Ma mère, mon père, ma sœur, mon frère, mon grand-père et ma grand-mère.",
      "emoji": "👪"
    },
    {
      "id": "phrase_4",
      "ar": "أُمِّي تُعِدُّ لَنَا طَعَامًا لَذِيذًا.",
