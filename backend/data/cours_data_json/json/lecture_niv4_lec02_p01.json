  "elements": [
    {
      "id": "phrase_1",
      "ar": "أَهْلًا بِكُمْ. أَنَا اسْمِي نَسِيم.",
      "fr": "Bienvenue. Je m'appelle Nassim.",
      "emoji": "👋"
