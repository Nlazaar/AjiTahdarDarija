{
  "name": "darija-backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "prisma": {
    "seed": "ts-node-dev --transpile-only prisma/seed.ts"
  },
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "nest build && npx tsc prisma/seed.ts --target ES2020 --module commonjs --esModuleInterop --outDir dist/src --rootDir prisma --skipLibCheck",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "ts-node-dev --transpile-only prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "import:content": "node scripts/importContent.js",
    "docker:build": "docker build -t YOUR_DOCKERHUB_USERNAME/darija-backend:latest .",
    "start:prod": "node dist/main.js",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "lint": "eslint 'src/**/*.{ts,js}' --fix"
  },
  "dependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@prisma/client": "^5.0.0",
    "@types/nodemailer": "^7.0.11",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "dotenv": "^16.0.0",
    "express-rate-limit": "^6.7.0",
    "helmet": "^7.0.0",
    "ioredis": "^5.3.1",
    "nodemailer": "^8.0.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "stripe": "^12.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^29.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "express-rate-limit": "^6.7.0",
    "jest": "^29.0.0",
    "prettier": "^3.8.1",
    "prisma": "^5.0.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
