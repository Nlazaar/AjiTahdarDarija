# Copier ce fichier en .env et remplir les valeurs
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/darija_db"
PORT=3001

# Générer avec : openssl rand -hex 32
JWT_SECRET=REMPLACER_PAR_UN_SECRET_FORT

SIGNALEMENT_EMAIL=contact@votredomaine.com
HOTMAIL_PASSWORD=MOT_DE_PASSE_APP_SPECIFIQUE

# Origines autorisées séparées par virgule
ALLOWED_ORIGINS=http://localhost:3000,https://votre-frontend.vercel.app

STRIPE_SECRET=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...
STRIPE_SUCCESS_URL=https://votre-frontend.vercel.app/premium/success
STRIPE_CANCEL_URL=https://votre-frontend.vercel.app/premium

REDIS_URL=redis://localhost:6379

ANTHROPIC_API_KEY=sk-ant-...

SENTRY_DSN=https://...@sentry.io/...

AUDIT_LOG_PATH=./logs/audit.log
