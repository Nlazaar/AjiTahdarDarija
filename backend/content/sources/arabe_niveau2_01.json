        "activities": [
          {
            "page": 1,
            "title": "ألصق بطاقات الحروف الناقصة",
            "objective": "Compléter les mots avec leur première lettre."
          },
          {
            "page": 2,
            "title": "أبحث عن الحرف و ألونه",
            "objective": "Repérer les lettres س et ي parmi des distracteurs."
          },
          {
            "page": 3,
            "title": "ألصق أجزاء الصور داخل المربعات",
            "objective": "Reconstruire et nommer les images أسد، فيل، مطر."
          },
          {
            "page": 4,
            "title": "أبحث عن الكلمة و أحيطها بخط",
            "objective": "Identifier le mot مطر parmi des mots proches."
          },
          {
            "page": 5,
            "title": "أبحث عن الكلمة و أحيطها بخط",
            "objective": "Identifier le mot فيل parmi des mots proches."
          },
          {
            "page": 6,
            "title": "أربط بين الكلمة و الصورة",
            "objective": "Associer أسد، مطر، فيل aux images correspondantes."
          },
          {
            "page": 7,
            "title": "أكمل الخطوط",
            "objective": "Tracer la lettre ف et le mot فيل."
          },
          {
            "page": 8,
            "title": "أرتب الأعمال التي أقوم بها بعد العودة من المدرسة",
            "objective": "Ordonner quatre actions de routine."
          },
          {
            "page": 9,
            "title": "أقص الصور",
            "objective": "Cartes à découper pour les exercices 1, 4 et 9."
          }
